#!/usr/bin/env bash

### INFO #######################################################################
### Script assumes you are using zen kernel. If another, do proper changes at 
###   Definitions
### Script designed around mine hyprland usecase. Modify it to get other DE
### Requirements: multilib enabled, internet conection and git is present.
### Feel free to modify script according to your needs.
### Script written using STRUCTURED paradigm with no jumps.
### Script uses autoconfig scripts provided in my other repos e.g. dot_hyprland.
### Script is designed for a fresh install with little preconfiguration, examine
###   before using in non-fresh environment due to possible overwriting.
### Script doesn't installs AUR packages, but it clones them into
###   ~/Downloads/AUR, it is your responsobility to check them and install them.
###   (makepkg -sri) for install.
### Script has been tested on ThinkPad T14 [amd] and ThinkPad X220 [intel]
###################################################### 2025-06-25 ### barysk ###

# Nvidia must be Turing arch or newer
#   if not: modify installed backages in NVIDIA_PKGS
GPU_VENDOR='' # provide: 'intel' or 'amd' or 'nvidia'

# If you have your configs, provide paths to it. If not leave empty.
DOTFILES_URL='' # if you have your dotfiles hosted somewhere
CONF_PATH='' # content will be moved to ~/.config/
FONTS_PATH='' # content will be moved to ~/.local/share/fonts/
BASHRC_PATH='' # will be moved to ~/.bashrc
BASHPROFILE_PATH='' # will be moved to ~/.bash_profile

ADD_PACKAGES=( # add/remove needed
	steam # steam
	prismlauncher # minecraft launcher
	lutris # Open Gaming Platform
	libreoffice-fresh # libreoffice
	libresprite # foss fork of aseprite
	anki # a smart spaced repetition flashcard program
	audacity # a program that lets you manipulate digital audio waveforms
	krita # Edit and paint images
	kdenlive # A non-linear video editor for Linux using the MLT video framework
	obs-studio # Free, open source software for live streaming and recording
	reaper # A complete digital audio production application for computers
	carla # Audio Plugin Host
	tailscale # A mesh VPN that makes it easy to connect your devies
	texlive # latex
	biber # latex: bibliography manager
	texlive-luatex # latex: lua support
	texlive-lang # latex: additional lang support
	zed # A high-performance, multiplayer code editor
)

### DEFINITIONS ################################################################

### AUR packages to clone ###
AUR_PKGS=(
	'https://aur.archlinux.org/tofi.git' # Tiny rofi / dmenu replacement for wlroots-based Wayland compositors.
	'https://aur.archlinux.org/vesktop-bin.git' # Discord client
	'https://aur.archlinux.org/brave-bin.git' # Web browser that blocks ads and trackers by default
	'https://aur.archlinux.org/auto-cpufreq.git' # Automatic CPU speed and power optimizer
	                                             # don't forget to ```sudo auto-cpufreq --install```
	'https://aur.archlinux.org/xpadneo-dkms.git' # Advanced Linux Driver for Xbox One Wireless Gamepad
	'https://aur.archlinux.org/localsend-bin.git' # An open source cross-platform alternative to AirDrop
	'https://aur.archlinux.org/blockbench-bin.git' # A low-poly 3D model editor
	'https://aur.archlinux.org/proton-ge-custom-bin.git' # A custom distribution of Valves Proton with various patches
	'https://aur.archlinux.org/bluetuith.git' # TUI-based bluetooth manager
	'https://aur.archlinux.org/pcsx2-latest-bin.git' # playstation2 emulator
	'https://aur.archlinux.org/rpcs3-bin.git' # playstation3 emulator
	'https://aur.archlinux.org/xnp2.git' # pc98 emulator
)

