### SCRIPT #####################################################################

if [[ $UID = 0 ]] ; then
	echo "A user without a sudo must run this script"
	exit 1
fi

printf "%s" "Druid will begin a ritual in "; sleep 0.2
printf "%s" "5" ; sleep 0.2 ; printf "%s" "." ; sleep 0.2 ; printf "%s" "." ; sleep 0.2
printf "%s" "4" ; sleep 0.2 ; printf "%s" "." ; sleep 0.2 ; printf "%s" "." ; sleep 0.2
printf "%s" "3" ; sleep 0.2 ; printf "%s" "." ; sleep 0.2 ; printf "%s" "." ; sleep 0.2
printf "%s" "2" ; sleep 0.2 ; printf "%s" "." ; sleep 0.2 ; printf "%s" "." ; sleep 0.2
printf "%s" "1" ; sleep 0.6

BASE_DIR=$(pwd)

echo "Creating home directory tree"
mkdir -p \
	"$HOME"/Applications \
	"$HOME"/Desktop \
	"$HOME"/Documents \
	"$HOME"/Downloads \
	"$HOME"/Games \
	"$HOME"/Music \
	"$HOME"/Pictures \
	"$HOME"/Projects \
	"$HOME"/Public \
	"$HOME"/Templates \
	"$HOME"/Videos

echo "Updating system"
sudo pacman -Syu

case "$GPU_VENDOR" in
	'intel')
		GPU_DRIVERS=("${INTEL_PKGS[@]}")
		;;
	'amd')
		GPU_DRIVERS=("${AMD_PKGS[@]}")
		;;
	'nvidia')
		GPU_DRIVERS=("${NVIDIA_PKGS[@]}")
		;;
	'')
		echo "Err :: Forgot to provide GPU vendor?"
		exit 2
		;;
	*)
		echo "Err :: Wrong GPU vendor."
		exit 3
		;;
esac

echo "Installing defined packages"

sudo pacman -S --needed \
	"${BASE_PKGS[@]}" \
	"${GPU_DRIVERS[@]}" \
	"${SESSION_PKGS[@]}" \
	"${TERMINAL_PKGS[@]}" \
	"${BASIC_PKGS[@]}" \
	"${DEVELOPMENT[@]}" \
	"${APPLICATIONS[@]}" \
	"${SOUND[@]}" \
	"${WINE[@]}" \
	"${THEMING[@]}" \
	"${BROWSERS[@]}" \
	"${ADD_PACKAGES[@]}"

echo "Downloading AUR packages to ~/Download/AUR"
mkdir -p "$HOME/Downloads/AUR"
cd "$HOME/Downloads/AUR"
for aur_pkg_url in "${AUR_PKGS[@]}"; do
	git clone "$aur_pkg_url"
done
cd "$BASE_DIR"

if [[ "$DOTFILES_URL" != "" ]]; then
	echo "clonning dotfiles"
	git clone "$DOTFILES_URL"
fi

if [[ "$CONF_PATH" != "" ]]; then
	echo "copying dotfiles"
	mkdir -p "$HOME/.config"
	cp -r "$CONF_PATH"/. "$HOME/.config/."
fi

if [[ "$FONTS_PATH" != "" ]]; then
	echo "copying fonts"
	mkdir -p "$HOME/.local/share/fonts"
	cp -r "$FONTS_PATH"/. "$HOME/.local/share/fonts/."
fi

if [[ "$BASHRC_PATH" != "" ]]; then
	echo "copying bashrc"
	cp "$BASHRC_PATH" "$HOME/.bashrc"
fi

if [[ "$BASHPROFILE_PATH" != "" ]]; then
	echo "copying bash_profile"
	cp "$BASHPROFILE_PATH" "$HOME/.bash_profile"
fi

echo "enabling xwayland-satellite"
systemctl --user enable xwayland-satellite

echo "enabling bluetooth.service"
sudo systemctl enable --now bluetooth.service

# update tldr
tldr --update

echo "Druid completed the ritual, now wellbeing is in thine hands."
echo 'Notes:'
echo 'You probably want to disable bluetooth autostart in /etc/bluetooth/main.conf'
echo "Reboot is advised"

